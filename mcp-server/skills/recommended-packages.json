{
  "name": "recommended-packages",
  "description": "Curated list of production-ready Flutter packages with latest versions (2024), including state management, networking, storage, UI components, and testing tools",
  "origin": "Flutter Dev Assistant",
  "year": 2024,
  "categories": {
    "stateManagement": {
      "riverpod": {
        "packages": {
          "flutter_riverpod": "^2.5.1",
          "riverpod_annotation": "^2.3.5",
          "riverpod_generator": "^2.4.0"
        },
        "why": "Type-safe, compile-time safety, excellent DevTools, no BuildContext dependency",
        "note": "Riverpod 3.0+ is available but includes breaking changes. Recommended to stay on 2.5.x for production until ecosystem stabilizes",
        "alternatives": ["bloc: ^8.1.4 / flutter_bloc: ^8.1.5 - For complex state with events", "provider: ^6.1.2 - Simpler, official recommendation"]
      }
    },
    "codeGeneration": {
      "freezed": {
        "packages": {
          "freezed_annotation": "^2.4.4",
          "freezed": "^2.5.2"
        },
        "why": "Eliminates boilerplate, immutability, union types, pattern matching",
        "note": "Freezed 3.0+ is available but includes breaking changes. Recommended to stay on 2.x for production"
      },
      "jsonSerialization": {
        "packages": {
          "json_annotation": "^4.8.0",
          "json_serializable": "^6.7.0"
        },
        "why": "Type-safe JSON serialization, reduces bugs"
      }
    },
    "networking": {
      "dio": {
        "packages": {
          "dio": "^5.4.0",
          "retrofit": "^4.0.0",
          "retrofit_annotation": "^8.0.0",
          "retrofit_generator": "^8.0.0"
        },
        "why": "Interceptors, request cancellation, file upload/download, better error handling"
      }
    },
    "storage": {
      "secureStorage": {
        "package": "flutter_secure_storage: ^9.0.0",
        "why": "Encrypted storage for sensitive data (tokens, passwords)",
        "essential": true
      },
      "localDatabase": {
        "hive": {
          "packages": {
            "hive_flutter": "^1.1.0",
            "hive": "^2.2.3",
            "hive_generator": "^2.0.1"
          },
          "why": "Fast, lightweight, type-safe, no SQL"
        },
        "alternatives": ["sqflite: ^2.3.0 - For complex queries", "isar: ^3.1.0 - Modern, very fast"]
      }
    },
    "uiComponents": {
      "cachedImages": {
        "package": "cached_network_image: ^3.3.0",
        "why": "Automatic caching, placeholder support, memory efficient"
      },
      "svg": {
        "package": "flutter_svg: ^2.0.0",
        "why": "Vector graphics, scalable, small file size"
      },
      "shimmer": {
        "package": "shimmer: ^3.0.0",
        "why": "Professional loading states"
      }
    },
    "navigation": {
      "goRouter": {
        "package": "go_router: ^13.0.0",
        "why": "Declarative routing, deep linking, type-safe navigation",
        "recommended": true
      }
    },
    "functionalProgramming": {
      "dartz": {
        "package": "dartz: ^0.10.1",
        "why": "Either type for error handling, functional utilities"
      }
    },
    "utilities": {
      "equatable": {
        "package": "equatable: ^2.0.5",
        "why": "Value equality without boilerplate"
      },
      "intl": {
        "package": "intl: ^0.19.0",
        "why": "Date formatting, number formatting, translations"
      },
      "uuid": {
        "package": "uuid: ^4.3.0",
        "why": "Generate unique identifiers"
      }
    },
    "testing": {
      "mocktail": {
        "package": "mocktail: ^1.0.0",
        "why": "Null-safe, no code generation, easy to use",
        "recommended": true
      },
      "blocTest": {
        "package": "bloc_test: ^9.1.0",
        "why": "Test blocs easily"
      }
    },
    "linting": {
      "flutterLints": {
        "package": "flutter_lints: ^3.0.0",
        "why": "Official Flutter linting rules"
      },
      "customLints": {
        "packages": {
          "custom_lint": "^0.6.0",
          "riverpod_lint": "^2.3.0"
        },
        "why": "Additional checks for Riverpod",
        "optional": true
      }
    },
    "firebase": {
      "packages": {
        "firebase_core": "^2.24.0",
        "firebase_auth": "^4.16.0",
        "cloud_firestore": "^4.14.0",
        "firebase_analytics": "^10.8.0",
        "firebase_crashlytics": "^3.4.0"
      },
      "note": "If needed"
    },
    "monitoring": {
      "sentry": {
        "package": "sentry_flutter: ^7.14.0",
        "why": "Error tracking, performance monitoring",
        "recommended": true
      }
    },
    "dependencyInjection": {
      "getIt": {
        "packages": {
          "get_it": "^7.6.0",
          "injectable": "^2.3.0",
          "injectable_generator": "^2.4.0"
        },
        "useWhen": ["Building modular applications", "Need advanced DI features", "Want compile-time safety", "Managing complex dependency graphs"],
        "note": "For large apps. Riverpod has built-in DI for simple to medium apps"
      }
    },
    "internationalization": {
      "official": {
        "packages": {
          "flutter_localizations": "sdk: flutter",
          "intl": "^0.19.0"
        },
        "features": ["Official Flutter support", "ARB file format", "Pluralization & gender", "Date/number formatting", "RTL support"],
        "recommended": true
      },
      "easyLocalization": {
        "package": "easy_localization: ^3.0.0",
        "features": ["JSON/YAML translations", "Simpler API", "Runtime locale switching", "Nested translations"],
        "alternative": true
      }
    },
    "platformIntegration": {
      "ffi": "^2.1.0",
      "platform": "^3.1.0",
      "device_info_plus": "^9.1.0",
      "package_info_plus": "^5.0.0"
    }
  },
  "packageSelectionCriteria": [
    "Maintenance: Active development, recent updates",
    "Popularity: High pub.dev score, many likes",
    "Documentation: Clear docs and examples",
    "Null Safety: Full null safety support",
    "Platform Support: iOS, Android, Web, Desktop",
    "Bundle Size: Impact on app size",
    "License: Compatible with your project"
  ],
  "packagesToAvoid": {
    "deprecated": ["provider < 6.0.0 - Use latest version", "shared_preferences < 2.0.0 - Old API", "http < 1.0.0 - Security issues"],
    "unmaintained": ["Packages not updated in 12+ months", "Packages with many unresolved issues", "Packages with security vulnerabilities"],
    "alternativesExist": ["get - Use Riverpod or Bloc instead", "flutter_bloc < 9.0.0 - Use latest version"]
  },
  "updateStrategy": {
    "monthly": ["Check for security updates", "Review changelog for breaking changes", "Test updates in development"],
    "quarterly": ["Major version updates", "Evaluate new packages", "Remove unused dependencies"],
    "commands": [
      "flutter pub outdated - Check for updates",
      "flutter pub upgrade - Update all packages",
      "flutter pub upgrade package_name - Update specific package",
      "flutter pub deps - Analyze dependencies"
    ]
  },
  "proTips": [
    "Pin critical versions in production",
    "Use dependency overrides sparingly",
    "Keep dev dependencies separate",
    "Document why you chose each package",
    "Monitor bundle size impact",
    "Set up automated dependency updates (Dependabot)"
  ],
  "resources": [
    "pub.dev - Official package repository",
    "Flutter Favorites - Curated packages",
    "Awesome Flutter - Community list (github.com/Solido/awesome-flutter)"
  ],
  "version": "1.0.0"
}
