{
  "name": "flutter-dev-assistant-mcp",
  "version": "1.0.0",
  "description": "MCP server for Flutter Dev Assistant commands",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "keywords": [
    "mcp",
    "flutter",
    "development",
    "assistant"
  ],
  "author": "andreimbro",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "fast-check": "^4.5.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5"
  }
}
